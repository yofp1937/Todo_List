<!-- 타이틀바와 하단바(달력 조정)까지 생성 -->
<UserControl x:Class="Calendar.View.MainTitleBarView"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- 커스텀 타이틀바 UI -->
        <!-- /Common/Util/WindowBehavior에 선언된 DependencyProperty(첨부 속성)를 Border에 적용함 -->
        <Border Style="{StaticResource TitleBarBorder}">
            <Grid>
                <!-- 타이틀 텍스트 -->
                <TextBlock Style="{StaticResource TitleTextBlock}" Text="Todo List"/>

                <!-- 불투명도 조절, 최소화, 최대화, 닫기 그룹 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- 불투명도 조절 슬라이더 -->
                    <Slider x:Name="OpacitySlider" Style="{StaticResource TitleOpacitySlider}"
                              Value="{Binding WindowOpacity, Mode=TwoWay}"/>
                    <!-- 최소화 버튼 -->
                    <Button Content="_" Style="{StaticResource MinimizeBtn}"
                                Command="{Binding MinimizeWindowCommand}"/>
                    <!-- 최대화 버튼 -->
                    <Button Content="ㅁ" Style="{StaticResource MaximizeBtn}"
                                Command="{Binding MaximizeWindowCommand}"/>
                    <!-- 닫기 버튼 -->
                    <Button Content="X" Style="{StaticResource CloseWindowBtnInTitleBar}"
                                Command="{Binding CloseWindowCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>