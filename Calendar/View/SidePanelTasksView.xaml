<!-- Side Panel의 할 일, 끝난 일 View 생성 -->
<UserControl x:Class="Calendar.View.SidePanelTasksView"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- 최상단 날짜 표시 -->
            <Border Grid.Row="0">
                <TextBlock Text="{Binding CalendarVM.SelectedDay.Date, StringFormat='yyyy년 MM월 dd일 (dddd)'}"
                                Style="{StaticResource TextBlock15ptBold}" xml:lang="ko-KR"/>
            </Border>
            
            <!-- 할 일 표시 -->
            <ContentControl Grid.Row="1" Style="{StaticResource CustomGroupBoxStyle}" Tag="할 일">
                <ScrollViewer VerticalScrollBarVisibility="Visible" Background="LightGray">
                    <!-- CalendarVM.SelectedDay.AllTasks에서 모든 정보를 가져와 IsCompleted가 true인 데이터만 표시 -->
                    <ItemsControl ItemsSource="{Binding CalendarVM.SelectedDay.AllTasksView}"
                                        ItemTemplate="{StaticResource TaskItemTemplate}"
                                        ItemContainerStyle="{StaticResource TodoTaskItemStyle}"/>
                </ScrollViewer>
            </ContentControl>

            <!-- 끝낸 일 표시 -->
            <ContentControl Grid.Row="2" Style="{StaticResource CustomGroupBoxStyle}" Tag="끝낸 일">
                <ScrollViewer VerticalScrollBarVisibility="Visible" Background="LightGray">
                    <!-- CalendarVM.SelectedDay.AllTasks에서 모든 정보를 가져와 IsCompleted가 false인 데이터만 표시 -->
                    <ItemsControl ItemsSource="{Binding CalendarVM.SelectedDay.AllTasksView}"
                                        ItemTemplate="{StaticResource TaskItemTemplate}"
                                        ItemContainerStyle="{StaticResource CompletedTaskItemStyle}"/>
                </ScrollViewer>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>