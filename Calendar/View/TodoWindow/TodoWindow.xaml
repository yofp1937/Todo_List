<!-- 규칙 추가, 일정 추가를 눌렀을때 나오는 Window 창 -->
<Window x:Class="Calendar.View.TodoWindow.TodoWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
             Title="일정 추가 윈도우" Height="427"
             WindowStyle="None"
             WindowStartupLocation="CenterOwner"
             Style="{StaticResource TodoWindowChrome}"
             ResizeMode="NoResize"
             Background="LightGray">

    <!-- 창 테두리용 Border -->
    <Border BorderBrush="Black" BorderThickness="1">
        <Grid>
            <!-- 1.타이틀 바        
                   2.내부 내용(날짜(주기) 선택, 제목, 내용 등)
                   3.상태 RadioBtn
                   4.등록, 취소 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 UI -->
            <Border Grid.Row="0" Style="{StaticResource TitleBarBorder}">
                <!-- 타이틀 텍스트 -->
                <TextBlock Text="{Binding MainBarTitleText}" Style="{StaticResource TitleTextBlock}"/>
            </Border>

            <!-- (규칙, 일정) 추가 -->
            <ContentControl Grid.Row="1" Content="{Binding}" Style="{StaticResource TodoContentStyle}"/>

            <!-- 상태 RadioBtn (IsAddMode가 true일 경우에만 표시 됨) -->
            <StackPanel Grid.Row="2" Style="{StaticResource AddModeStackPanel}">
                <StackPanel.Resources>
                    <Style TargetType="RadioButton" BasedOn="{StaticResource BottomTextRadioButton20}">
                        <Setter Property="Margin" Value="20, 5, 20, 5"/>
                    </Style>
                </StackPanel.Resources>
                <RadioButton Content="완료" Foreground="Green"
                                   IsChecked="{Binding CurrentStatus, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Completion}"/>
                <RadioButton Content="실패" Foreground="Red"
                                   IsChecked="{Binding CurrentStatus, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Failure}"/>
                <RadioButton Content="대기" 
                                   IsChecked="{Binding CurrentStatus, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Waiting}"/>
            </StackPanel>

            <!-- 등록, 취소 버튼 -->
            <Border Grid.Row="3" Padding="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding WarningText}" Style="{StaticResource TodoWindowWarningText}"/>
                    <Button Content="삭제" Style="{StaticResource TodoWindowDeleteBtn}"
                                Command="{Binding DeleteCommand}"/>
                    <Button Content="등록" Style="{StaticResource TodoWindowBottomBtn}"
                                Command="{Binding SubmitCommand}"/>
                    <Button Content="취소" Style="{StaticResource TodoWindowBottomBtn}"
                                Command="{Binding CloseWindowCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>