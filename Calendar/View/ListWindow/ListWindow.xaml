<!-- 일정 목록을 눌렀을때 나오는 Window 창 -->
<Window x:Class="Calendar.View.ListWindow.ListWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
             Title="목록 윈도우" Height="450" Width="800"
             WindowStyle="None"
             WindowStartupLocation="CenterOwner"
             Style="{StaticResource CustomWindowChrome}"
             ResizeMode="NoResize"
             Background="LightGray">

    <!-- 창 테두리용 Border -->
    <Border BorderBrush="Black" BorderThickness="1">
        <Grid>
            <!-- 1.타이틀 바        
                   2.일정, 규칙, 정렬 선택
                   3.일정, 규칙 목록
                   4.등록, 취소 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 UI -->
            <Border Grid.Row="0" Style="{StaticResource TitleBarBorder}">
                <!-- 타이틀 텍스트 -->
                <TextBlock Text="{Binding MainBarTitleText}" Style="{StaticResource TitleTextBlock}"/>
            </Border>

            <!-- 일정 or 규칙, 정렬 선택 -->
            <Border Grid.Row="1">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="일정"  IsChecked="{Binding ListType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=ScheduleDataType}"
                                       Style="{StaticResource FileTabRadioButton}"/>
                    <RadioButton Content="규칙"  IsChecked="{Binding ListType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=RoutineDataType}"
                                       Style="{StaticResource FileTabRadioButton}"/>
                    <RadioButton Content="과거 규칙"  IsChecked="{Binding ListType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=RoutineRecordType}"
                                       Style="{StaticResource FileTabRadioButton}"/>
                </StackPanel>
            </Border>

            <!-- 일정 규칙 목록 -->
            <ContentControl Grid.Row="2" Content="{Binding}" Style="{StaticResource ListViewContentStyle}"/>

            <!-- 삭제, 수정, 취소 -->
            <Border Grid.Row="3" Padding="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="삭제" Style="{StaticResource TodoWindowBottomBtn}" Command="{Binding DeleteCheckedItemCommand}"/>
                    <Button Content="수정" Style="{StaticResource TodoWindowBottomBtn}" Command="{Binding EditBtnAndDoubleClickCommand}"
                                CommandParameter="{Binding SelectedItem}"/>
                    <Button Content="취소" Style="{StaticResource TodoWindowBottomBtn}" Command="{Binding CloseWindowCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>