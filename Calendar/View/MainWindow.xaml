<!-- 메인 Window -->
<Window x:Class="Calendar.View.MainWindow"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:tb="http://www.hardcodet.net/taskbar"
              xmlns:view="clr-namespace:Calendar.View"
              xmlns:viewC="clr-namespace:Calendar.View.Calendar"
        
              Title="TODO List" Height="800" MinHeight="600" Width="1100" MinWidth="750"
              WindowStyle="None"
              Style="{StaticResource CustomWindowChrome}"
              AllowsTransparency="True"
              Background="LightGray">
    <Grid>
        <!-- 전체 영역 크기 조절 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"/>
            <ColumnDefinition Width="75*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <view:MainTitleBarView Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"/>
        <viewC:CalendarControlBarView Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"/>
        <view:SidePanelTasksView Grid.Column="0" Grid.Row="2"/>
        <viewC:CalendarView DataContext="{Binding CalendarVM}" Grid.Column="1" Grid.Row="2"/>
    </Grid>
</Window>
