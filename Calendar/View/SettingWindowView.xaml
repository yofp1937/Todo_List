<!-- 설정 눌렀을때 나오는 Window 창 -->
<Window x:Class="Calendar.View.SettingWindowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
             Title="설정 윈도우" Width="300" Height="400"
             WindowStyle="None"
             WindowStartupLocation="CenterOwner"
             Style="{StaticResource CustomWindowChrome}"
             ResizeMode="NoResize"
             Background="LightGray">

    <!-- 창 테두리용 Border -->
    <Border BorderBrush="Black" BorderThickness="1">
        <Grid>
            <!-- 1.타이틀 바        
                   2.설정 종류
                   3.적용, 저장, 닫기 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 UI -->
            <Border Grid.Row="0" Style="{StaticResource TitleBarBorder}">
                <!-- 타이틀 텍스트 -->
                <TextBlock Text="{Binding MainBarTitleText}" Style="{StaticResource TitleTextBlock}"/>
            </Border>

            <!-- 설정 종류 -->
            <Border Grid.Row="1" Padding="10">
                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- 자동 실행 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Text="자동 실행: " Style="{StaticResource TextBlock12ptBold}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <StackPanel.Resources>
                            <Style TargetType="RadioButton" BasedOn="{StaticResource BottomTextRadioButton12}">
                                <Setter Property="Margin" Value="10, 5, 10, 5"/>
                            </Style>
                        </StackPanel.Resources>
                        <RadioButton Content="자동 실행 켜기"
                                           IsChecked="{Binding IsAutoStartEnabled,
                                                            Converter={StaticResource BoolToRadioButtonConverter}, ConverterParameter=true}"/>
                        <RadioButton Content="자동 실행 끄기"
                                           IsChecked="{Binding IsAutoStartEnabled,
                                                            Converter={StaticResource BoolToRadioButtonConverter}, ConverterParameter=false}"/>
                    </StackPanel>
                    <!-- 최소화 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Text="최소화: " Style="{StaticResource TextBlock12ptBold}"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <StackPanel.Resources>
                            <Style TargetType="RadioButton" BasedOn="{StaticResource BottomTextRadioButton12}">
                                <Setter Property="Margin" Value="10, 5, 10, 5"/>
                            </Style>
                        </StackPanel.Resources>
                        <RadioButton Content="최소화"
                                           IsChecked="{Binding CurrentMinimizeMode, Converter={StaticResource EnumToBoolConverter},
                                                            ConverterParameter=Taskbar}"/>
                        <RadioButton Content="시스템 트레이"
                                           IsChecked="{Binding CurrentMinimizeMode, Converter={StaticResource EnumToBoolConverter},
                                                            ConverterParameter=SystemTray}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 적용, 저장, 닫기 버튼 -->
            <Border Grid.Row="3" Padding="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="적용" Style="{StaticResource SettingWindowBottomBtn}"
                                Command="{Binding ApplyCommand}"/>
                    <Button Content="저장" Style="{StaticResource SettingWindowBottomBtn}"
                                Command="{Binding SubmitCommand}"/>
                    <Button Content="닫기" Style="{StaticResource SettingWindowBottomBtn}"
                                Command="{Binding CloseWindowCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>