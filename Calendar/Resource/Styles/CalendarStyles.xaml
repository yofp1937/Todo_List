<!-- Calendar의 Style을 정의하는곳 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Border Style -->
    <Style TargetType="Border" x:Key="BaseCalendarBorderStyle">
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="5, 0, 0, 5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Black"/>
    </Style>

    <!-- Base ItemControl Style -->
    <Style TargetType="ItemsControl" x:Key="BaseCalendarItemsControl">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- WeekHeader Style -->
    <!-- Border는 BaseBorderStyle에서 변동 없음 -->
    <Style TargetType="Border" x:Key="WeekHeaderBorderStyle" BasedOn="{StaticResource BaseCalendarBorderStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding}" Value="Sun">
                <Setter Property="BorderBrush" Value="Crimson"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Sat">
                <Setter Property="BorderBrush" Value="Blue"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!-- TextBlock은 15pt, Bold 가운데 정렬 -->
    <Style TargetType="TextBlock" x:Key="WeekHeaderTextStyle" BasedOn="{StaticResource TextBlock15ptBold}">
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding}" Value="Sun">
                <Setter Property="Foreground" Value="Crimson"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Sat">
                <Setter Property="Foreground" Value="Blue"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Calendar Border Style -->
    <Style TargetType="Border" x:Key="CalendarDayBorderStyle" BasedOn="{StaticResource BaseCalendarBorderStyle}">
        <Style.Triggers>
            <!-- IsCurrentMonth의 값이 false면 테두리 회색으로 변경 -->
            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="false">
                <Setter Property="BorderBrush" Value="DimGray"/>
            </DataTrigger>
            <!-- IsCurrentMonth의 값이 True고, DayOfWeek의 값이 Sunday면 테두리 짙은 빨간색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding DayOfWeek}" Value="Sunday"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="Crimson"/>
            </MultiDataTrigger>
            <!-- IsCurrent의 값이 True고, DayOfWeek의 값이 Saturday면 테두리 파란색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding DayOfWeek}" Value="Saturday"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="Blue"/>
            </MultiDataTrigger>
            <!-- IsCurrentMonth가 true고, IsHoliday가 true면 글씨 짙은 빨간색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding IsHoliday}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="Crimson"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Calendar 날짜 생성 -->
    <Style TargetType="Button" x:Key="CalendarDayButtonStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="DayBorder" Style="{StaticResource CalendarDayBorderStyle}"
                                Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="DayBorder" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="DayBorder" Property="Background" Value="#10000000"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 날짜 뒤에 투명한 초록 원을 그려서 오늘인지 표시 -->
    <Style TargetType="Ellipse" x:Key="TodayEllipseStyle">
        <Setter Property="Width" Value="17.5"/>
        <Setter Property="Height" Value="17.5"/>
        <Setter Property="Fill" Value="#4CAF50"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsToday}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- TextBlock의 기본 색상은 Black -->
    <Style TargetType="TextBlock" x:Key="CalendarDayTextStyle">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Style.Triggers>
            <!-- IsCurrentMonth의 값이 false면 글씨 회색으로 변경하고, 크기는 10pt, 폰트는 이탤릭체(기울어짐)로 변경 -->
            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="false">
                <Setter Property="Foreground" Value="DimGray"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontStyle" Value="Italic"/>
            </DataTrigger>
            <!-- IsCurrentMonth가 true고, DayOfWeek이 Sunday면 글씨 짙은 빨간색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding DayOfWeek}" Value="Sunday"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Foreground" Value="Crimson"/>
            </MultiDataTrigger>
            <!-- IsCurrentMonth가 true고, DayOfWeek이 Saturday면 글씨 파란색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding DayOfWeek}" Value="Saturday"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Foreground" Value="Blue"/>
            </MultiDataTrigger>
            <!-- IsCurrentMonth가 true고, IsHoliday가 true면 글씨 짙은 빨간색으로 변경 -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                    <Condition Binding="{Binding IsHoliday}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Foreground" Value="Crimson"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBlock" x:Key="CalendarHolidayTextStyle">
        <Setter Property="Foreground" Value="Crimson"/>
        <Setter Property="FontSize" Value="10"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="false">
                <Setter Property="Foreground" Value="DimGray"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--
    MultiDataTrigger에서 ItemsControl.AlternationIndex에 바로 접근하려 시도했는데
    ContentPresent가 생성되자마자 접근하여 AlternationIndex가 부여되기도 전에 값을 찾으려해 오류가 발생함
    그래서 AlternationIndex 값을 Grid에 부여해서 Grid의 태그값으로 아이템의 순서를 결정하고
    Grid가 생성된다음 Grid의 Tag를 읽어와서 그 값을 기반으로 MultiDataTrigger에서 인식하게 만듦
    -->
    <Style TargetType="Grid" x:Key="CalendarTasksRootGridStyle">
        <Setter Property="Tag" Value="{Binding Path=(ItemsControl.AlternationIndex), 
                                                   RelativeSource={RelativeSource Mode=FindAncestor, 
                                                   AncestorType={x:Type ContentPresenter}}}"/>
    </Style>

    <!-- Calendar에 표시될 할 일 텍스트들의 Base -->
    <Style TargetType="TextBlock" x:Key="BaseCalendarTodoText">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="1,1,0,0"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Style.Triggers>
            <!-- IsFailure가 true면 빨간색으로 표시 -->
            <DataTrigger Binding="{Binding IsFailure}" Value="true">
                <Setter Property="Foreground" Value="Crimson"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- SummaryText의 Style -->
    <Style TargetType="TextBlock" x:Key="SummaryTextBlock" BasedOn="{StaticResource BaseCalendarTodoText}">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <!-- Parameter에 n 넣으면 AllTasksView.Count가 n개 이상일때 SummaryText를 변경함 -->
        <Setter Property="Text" Value="{Binding Path=DataContext.AllTasksView, RelativeSource={RelativeSource AncestorType=Button}, 
                                                   Converter={StaticResource TaskSummaryTextConverter}, ConverterParameter=7}"/>
    </Style>

    <!-- 날짜 칸 내부의 일정, 규칙 표시용 StackPanel Style -->
    <Style TargetType="StackPanel" x:Key="TaskStackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <!-- Parameter로 n넣으면 n번째 StackPanel 숨김 -->
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent},
                                            Converter={StaticResource ComparisonToVisibilityConverter}, ConverterParameter=6}" Value="Collapsed">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Symbol용 텍스트 스타일 -->
    <Style TargetType="TextBlock" x:Key="CalendarSymbolStyle" BasedOn="{StaticResource BaseCalendarTodoText}">
        <Setter Property="Text" Value="● "/>
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <!-- AllTasks의 데이터 타입이 RoutineInstance면 Symbol 변경 -->
            <DataTrigger Binding="{Binding TypePriority}" Value="2">
                <Setter Property="Text" Value="○ "/>
            </DataTrigger>
            <!-- IsCompleted가 true면 Symbol 제거 -->
            <DataTrigger Binding="{Binding IsCompletion}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Calnedar에 표시될 일정, 규칙 텍스트 스타일 -->
    <Style TargetType="TextBlock" x:Key="CalendarTaskTextStyle" BasedOn="{StaticResource BaseCalendarTodoText}">
        <Style.Triggers>
            <!-- 완료한 일정은 줄긋기, 기울어짐 -->
            <DataTrigger Binding="{Binding IsCompletion}" Value="True">
                <Setter Property="FontStyle" Value="Italic"/>
                <Setter Property="Foreground" Value="DimGray"/>
                <Setter Property="TextDecorations" Value="Strikethrough"/>
                <Setter Property="Opacity" Value="0.3"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>