п»ҝ<!-- Base Styleмқ„ м •мқҳн•ҳлҠ”кіі -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    WindowChrome мҠӨнғҖмқј
    WidowChromeмқҖ мңҲлҸ„мҡ° н…Ңл‘җлҰ¬мҷҖ нғҖмқҙнӢҖ л°”к°Җ мЎҙмһ¬н•ҳлҠ”кіімқ„ мқҳлҜён•ңлӢӨ.
    лӮң OSм—җм„ң м§Җмӣҗн•ҳлҠ” мңҲлҸ„мҡ° л°”лҘј м§Җмӣ кё°л•Ңл¬ём—җ мөңмҶҢнҷ”, мөңлҢҖнҷ”, лӢ«кё°, нҒ¬кё°мЎ°м Ҳ, мң„м№ҳмЎ°м Ҳмқ„ м§Ғм ‘ кө¬нҳ„н•ҙм•јн•ңлӢӨ.
    м•„лһҳм—җм„ң нҒ¬кё°мЎ°м Ҳ кё°лҠҘмқ„ OSм—җм„ң м§Җмӣҗл°ӣкё°мң„н•ҙ Window.Styleмқ„ мӮ¬мҡ©н•ҙ WindowChromeмқҳ кё°лҠҘмқ„ м„Өм •н•ңлӢӨ.
    
    ResizeBorderThicknessлҠ” мңҲлҸ„мҡ° н…Ңл‘җлҰ¬лҘј нҒҙлҰӯ-л“ңлһҳк·ён•ҳм—¬ м°Ҫ нҒ¬кё°мЎ°м Ҳмқ„н• л•Ң нҒҙлҰӯ к°ҖлҠҘн•ң мҳҒм—ӯмқҳ нҒ¬кё°лҘј л§җн•ңлӢӨ.
    CaptionHeigtлҠ” OSк°Җ мқёмӢқн•ҳлҠ” мғҒлӢЁ нғҖмқҙнӢҖл°”мқҳ нҒ¬кё°лҘј мқҳлҜён•ңлӢӨ.(к·ё м•„лһҳмһҲлҠ” м»ЁнҠёлЎӨл“ӨмқҖ нҒҙлҰӯ л¶Ҳк°ҖлҠҘ)
    CornerRadiusлҠ” н…Ңл‘җлҰ¬лҘј кіЎм„ нҳ•мңјлЎң л§Ңл“ңлҠ” кё°лҠҘмқҙлӢӨ.
    GlassFrameThicknessлҠ” м°Ҫ мҷёкіҪмқҳ кёҖлһҳмҠӨ мҳҒм—ӯмқҳ л‘җк»ҳлҘј мқҳлҜён•ңлӢӨ(Glass нҡЁкіјлҘј л§Ңл“Өл•Ң мӮ¬мҡ©)
    UseAeroCaptionButtonsлҠ” кё°ліё мөңмҶҢнҷ”, мөңлҢҖнҷ”, лӢ«кё° лІ„нҠјмқ„ мӮ¬мҡ©н• м§Җ л§җм§Җ м—¬л¶ҖмқҙлӢӨ(WindowStyleмқҙ Noneмқјл•ҢлҠ” Trueм—¬лҸ„ лҜёмһ‘лҸҷ)
    -->
    <Style TargetType="Window" x:Key="CustomWindowChrome">
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome
                    ResizeBorderThickness="8"
                    CaptionHeight="0"
                    CornerRadius="0"
                    GlassFrameThickness="0"
                    UseAeroCaptionButtons="True"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock Base (15pt, Bold) -->
    <Style TargetType="TextBlock" x:Key="TextBlock15ptBold">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    
    <!-- TextBlock Base (12pt, Bold) -->
    <Style TargetType="TextBlock" x:Key="TextBlock12ptBold">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    
    <!-- TextBlock Italic (12pt, Italic) -->
    <Style TargetType="TextBlock" x:Key="TextBlockItalic">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="Foreground" Value="Crimson"/>
    </Style>

    <!--
    TextBox PlaceHolder кө¬нҳ„
    мӮ¬мҡ©лІ•: Style="{StaticResource TextBoxPlacHolder}" м„ м–ё нӣ„ м»ЁнҠёлЎӨ лӮҙм—җ Tag="PlaceHolderлЎң ліҙм—¬мЈјкі мӢ¶мқҖ лӮҙмҡ©" мһ…л Ҙ
    -->
    <Style TargetType="TextBox" x:Key="TextBoxPlaceHolder">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="Border" BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                               HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <TextBlock x:Name="PlaceHolder" Text="{TemplateBinding Tag}" 
                                       FontStyle="Italic" Foreground="Gray" IsHitTestVisible="False" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PlaceHolder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- RadioButtonмқҳ Textк°Җ мҳҶм—җ н‘ңмӢңлҗҳлҠ”кұё м•„лһҳмӘҪм—җ н‘ңмӢңлҗҳкІҢ л§Ңл“Өм–ҙмЈјлҠ” Style (нҒ¬кё° 20) -->
    <Style TargetType="RadioButton" x:Key="BottomTextRadioButton20">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Vertical" Background="Transparent">
                        <Grid Height="20" Width="20" HorizontalAlignment="Center">
                            <Ellipse x:Name="OuterCircle" Stroke="Black" StrokeThickness="1" Fill="White"/>
                            <Ellipse x:Name="CheckMark" Fill="DodgerBlue" Margin="4" Visibility="Collapsed"/>
                        </Grid>

                        <ContentPresenter x:Name="contentPresenter" Margin="0,5,0,0"  
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                        </ContentPresenter>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="OuterCircle" Property="Stroke" Value="DodgerBlue"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- нҒ¬кё° 10 лІ„м „ -->
    <Style TargetType="RadioButton" x:Key="BottomTextRadioButton12">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Vertical" Background="Transparent">
                        <Grid Height="15" Width="15" HorizontalAlignment="Center">
                            <Ellipse x:Name="OuterCircle" Stroke="Black" StrokeThickness="1" Fill="White"/>
                            <Ellipse x:Name="CheckMark" Fill="DodgerBlue" Margin="4" Visibility="Collapsed"/>
                        </Grid>

                        <ContentPresenter x:Name="contentPresenter" Margin="0,5,0,0"  
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                        </ContentPresenter>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="OuterCircle" Property="Stroke" Value="DodgerBlue"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBoxмқҳ Textк°Җ мҳҶм—җ н‘ңмӢңлҗҳлҠ”кұё м•„лһҳмӘҪм—җ н‘ңмӢңлҗҳкІҢ л§Ңл“Өм–ҙмЈјлҠ” Style -->
    <Style TargetType="CheckBox" x:Key="BottomTextCheckBox">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Vertical" Background="Transparent">
                        <Grid Height="20" Width="20" HorizontalAlignment="Center">
                            <Border x:Name="OuterBorder" CornerRadius="1"
                                        BorderBrush="Black"  BorderThickness="1" Background="White" />
                            <Rectangle x:Name="CheckMark" Visibility="Collapsed"
                                            Fill="DodgerBlue" Margin="4" />
                        </Grid>

                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                        FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="DodgerBlue"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="DodgerBlue"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DatePickerTextBoxм—җ нӮӨліҙл“ңлЎң к°’ мһ…л Ҙ лӘ»н•ҳкІҢ м°ЁлӢЁн•ҙмЈјлҠ” м „м—ӯ Style -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False"/>
    </Style>

</ResourceDictionary>