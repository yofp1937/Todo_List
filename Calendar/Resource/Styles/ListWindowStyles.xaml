<!-- ListWindowView.xaml에서 사용하는 Style -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:modelEnum="clr-namespace:Calendar.Model.Enum"
                            xmlns:view="clr-namespace:Calendar.View.ListWindow">

    <!-- 라디오 버튼을 파일철 구분탭처럼 변경 -->
    <Style TargetType="RadioButton" x:Key="FileTabRadioButton" >
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="TabBorder" BorderBrush="Black" BorderThickness="1,1,1,0" 
                               CornerRadius="5,5,0,0" Background="#BBBBBB" Margin="0,5,0,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                            <Setter TargetName="TabBorder" Property="Margin" Value="0,2,0,-1"/>
                            <Setter Property="Panel.ZIndex" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 조건에따라 ContentControl의 내용 변경 -->
    <Style TargetType="ContentControl" x:Key="ListViewContentStyle">
        <Style.Triggers>
            <DataTrigger Binding="{Binding ListType}" Value="{x:Static modelEnum:TodoListType.ScheduleDataType}">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <view:ScheduleDataListView/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding ListType}" Value="{x:Static modelEnum:TodoListType.RoutineDataType}">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <view:RoutineDataListView/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding ListType}" Value="{x:Static modelEnum:TodoListType.RoutineRecordType}">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <view:RoutineRecordListView/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ListView에 더블클릭 이벤트 부착 -->
    <Style x:Key="ListViewItemDoubleClickStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                                  Command="{Binding DataContext.EditBtnAndDoubleClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#CCE8FF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F2F9FF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 날짜(StartDate, EndDate, Date) 표시 CellTemplate -->
    <DataTemplate x:Key="StartDateCellTemplate">
        <TextBlock Text="{Binding StartDate, StringFormat='yyyy-MM-dd'}"/>
    </DataTemplate>
    <DataTemplate x:Key="EndDateCellTemplate">
        <TextBlock>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{Binding EndDate, StringFormat='yyyy-MM-dd'}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsIndefinite}" Value="True">
                            <Setter Property="Text" Value="기한 없음"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>
    <DataTemplate x:Key="DateCellTemplate">
        <TextBlock Text="{Binding Date, StringFormat='yyyy-MM-dd'}"/>
    </DataTemplate>
    
    <!-- 반복 형태(RoutineType) 표시 CellTemplate -->
    <DataTemplate x:Key="RoutineTypeCellTemplate">
        <TextBlock Text="{Binding RoutineType, Converter={StaticResource RoutineTypeToTextConverter}}">
        </TextBlock>
    </DataTemplate>

    <!-- 주기(Frequency) 표시 CellTemplate -->
    <DataTemplate x:Key="FrequencyCellTemplate">
        <TextBlock>
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource RoutineFrequencyToTextConverter}">
                    <Binding Path="Frequency"/>
                    <Binding Path="RoutineType"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </DataTemplate>

    <!-- 상태(Status) 표시 CellTemplate -->
    <DataTemplate x:Key="StatusCellTemplate">
        <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static modelEnum:TodoStatus.Completion}">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static modelEnum:TodoStatus.Failure}">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static modelEnum:TodoStatus.Waiting}">
                            <Setter Property="Foreground" Value="Black"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>
</ResourceDictionary>