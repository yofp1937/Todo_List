<!-- (Add,Edit)TodoWindow에서 사용될 Style 정의 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:view="clr-namespace:Calendar.View.TodoWindow">

    <!-- 조건에따라 Window 창의 Width 값 변경 -->
    <Style TargetType="Window" x:Key="TodoWindowChrome" BasedOn="{StaticResource CustomWindowChrome}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRoutine}" Value="true">
                <Setter Property="Width" Value="600"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRoutine}" Value="false">
                <Setter Property="Width" Value="300"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 조건에따라 ContentControl의 내용 변경 -->
    <Style TargetType="ContentControl" x:Key="TodoContentStyle">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRoutine}" Value="true">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <view:RoutineView/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsRoutine}" Value="false">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <view:ScheduleView/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="StackPanel" x:Key="AddModeStackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAddMode}" Value="true">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBlock" x:Key="TodoWindowWarningText" BasedOn="{StaticResource TextBlockItalic}">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="2.5"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsWarningVisible}" Value="true">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- 등록, 취소 Btn Style -->
    <Style TargetType="Button" x:Key="TodoWindowBottomBtn">
        <Setter Property="Margin" Value="2.5"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="25"/>
    </Style>
    <!-- 삭제 Btn Style -->
    <Style TargetType="Button" x:Key="TodoWindowDeleteBtn" BasedOn="{StaticResource TodoWindowBottomBtn}">
        <Setter Property="Foreground" Value="Crimson"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAddMode}" Value="true">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- 일정, 규칙 추가 공통 제목(TextBox) 스타일 -->
    <Style TargetType="TextBox" x:Key="TitleTextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <!-- 일정, 규칙 추가 공통 내용(TextBox) 스타일 -->
    <Style TargetType="TextBox" x:Key="ContentTextBox" BasedOn="{StaticResource TextBoxPlaceHolder}">
        <Setter Property="Tag" Value="내용을 입력하세요."/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="AcceptsReturn" Value="True"/>
    </Style>

    <!-- 규칙 추가의 종료 날짜를 IsIndefinite에따라 활성화/비활성화 -->
    <Style TargetType="DatePicker" x:Key="AddRoutineEndDate">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsIndefinite}" Value="true">
                <Setter Property="IsEnabled" Value="False"/>
                <Setter Property="Opacity" Value="0.5"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 기한 없음 TextBlock -->
    <Style TargetType="TextBlock" x:Key="IndefiniteTextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="2.5"/>
    </Style>
    
    <!-- 기한 없음 CheckBox -->
    <Style TargetType="CheckBox" x:Key="IndefiniteCheckBox">
        <Setter Property="Margin" Value="2.5"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 일간 반복 TextBlock -->
    <Style TargetType="TextBlock" x:Key="DailyRoutineTextBlock">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="Gray"/>
    </Style>
    
    <!-- 월간, 연간 규칙 날짜 선택 TextBlock -->
    <Style TargetType="TextBlock" x:Key="RoutineSelectDateTextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
    </Style>
    <!-- 월간, 연간 규칙 Button Style -->
    <Style TargetType="Button" x:Key="MonthlyAndYearlyRoutineBtn">
        <Setter Property="Margin" Value="5,0,0,5"/>
        <Setter Property="Width" Value="45"/>
        <Setter Property="Height" Value="22.5"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    
    <!-- 월간 규칙 추가 ListBox -->
    <Style TargetType="ListBox" x:Key="MonthlySelectedDaysListBox">
        <Setter Property="SelectionMode" Value="Extended"/>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding StringFormat={}{0}일}"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 연간 규칙 추가의 날짜 선택을 연도는 안보이게끔 적용 -->
    <Style TargetType="DatePicker" x:Key="YearlyRoutineDatePicker">
        <Setter Property="Width" Value="70"/>
        <Setter Property="SelectedDateFormat" Value="Short"/>
        <Style.Resources>
            <Style TargetType="DatePickerTextBox">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePickerTextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <TextBox Text="{Binding Path=SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker},
                                             StringFormat={}{0:MM-dd}, Mode=OneWay}" 
                                             IsReadOnly="True" BorderThickness="0" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <!-- 연간 규칙 추가 ListBox -->
    <Style TargetType="ListBox" x:Key="YearlySelectedDaysListBox">
        <Setter Property="SelectionMode" Value="Extended"/>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding StringFormat={}{0:MM월 dd일}}"/>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>