<!-- SidePanelTasksView.xaml에서 사용하는 Style -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="SlimScrollBarThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="#888888" RadiusX="3" RadiusY="3" Width="6" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsMouseOver}">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollBarThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContentControl을 GroupBox처럼 스타일 적용 -->
    <Style TargetType="ContentControl" x:Key="CustomGroupBoxStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid Margin="0,15,0,5">
                        <Border BorderBrush="Black" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter Margin="5,10,5,5"/>
                        </Border>
                        <TextBlock Text="{TemplateBinding Tag}" Background="LightGray" 
                                        Margin="10,-8,0,0" FontWeight="Bold"
                                        VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="TaskItemTemplate">
        <Grid x:Name="ItemPanel">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                      CommandParameter="{Binding}"/>
            </Grid.InputBindings>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox VerticalAlignment="Center" Margin="5"
                            IsChecked="{Binding Status, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, 
                                             ConverterParameter=Completion, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Column="1" x:Name="TypeSymbol" Text="○ "
                            VerticalAlignment="Center" FontSize="12" Margin="0,0,0,3.5"/>
            <TextBlock Grid.Column="2" Text="{Binding TodoTitle}" VerticalAlignment="Center"
                            TextWrapping="Wrap" LineStackingStrategy="BlockLineHeight" Margin="0,0,0,1"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding TypePriority}" Value="0">
                <Setter TargetName="TypeSymbol" Property="Text" Value="● "/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- 할 일 ContentPresenter Style -->
    <Style TargetType="ContentPresenter" x:Key="TodoTaskItemStyle">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCompletion}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 끝낸 일 ContentPresenter Style -->
    <Style TargetType="ContentPresenter" x:Key="CompletedTaskItemStyle">
        <Setter Property="TextBlock.TextDecorations" Value="Strikethrough"/>
        <Setter Property="TextBlock.Foreground" Value="Gray"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCompletion}" Value="False">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>