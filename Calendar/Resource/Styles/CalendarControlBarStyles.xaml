<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base Btn -->
    <Style TargetType="Button" x:Key="CalendarCotrolBarBaseBtn">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="MinWidth" Value="30"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Padding" Value="5"/>
    </Style>
    
    <!-- 일정, 규칙 추가 Btn -->
    <Style TargetType="Button" x:Key="CalendarAddTodoBtn" BasedOn="{StaticResource CalendarCotrolBarBaseBtn}">
        <Setter Property="ContextMenuService.Placement" Value="Bottom"/>
        <Setter Property="ContextMenuService.PlacementTarget" Value="{Binding RelativeSource={RelativeSource Self}}"/>
    </Style>

    <!-- 달력 이동 Btn -->
    <Style TargetType="Button" x:Key="CalendarMoveMonthBtnStyle">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Width" Value="30"/>
    </Style>

    <!-- 달력 날짜 Btn -->
    <Style TargetType="Button" x:Key="CalendarSetMonthBtnStyle">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="MinWidth" Value="110"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Margin" Value="10,0,10,0"/>
        <Setter Property="Padding" Value="5"/>
    </Style>
    
    <!-- 목록 Btn -->
    <Style TargetType="Button" x:Key="CalendarListBtn" BasedOn="{StaticResource CalendarCotrolBarBaseBtn}">
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <!-- 설정 Btn -->
    <Style TargetType="Button" x:Key="CalendarSettingBtn" BasedOn="{StaticResource CalendarCotrolBarBaseBtn}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
    </Style>
</ResourceDictionary>