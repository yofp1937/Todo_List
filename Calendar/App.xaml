<Application x:Class="TODO_List.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup"
             ShutdownMode="OnMainWindowClose">
    <!-- 전체 애플리케이션에서 사용할 공통 스타일은 App.xaml에 정의하는것이 좋다고함 -->
    <Application.Resources>
        <!-- 외부 스타일 로드(Styles.xaml 파일 추가시 여기에서 경로를 추가해줘야함) -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Common/Converter/Converters.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/BaseStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/CalendarControlBarStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/CalendarStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/TodoWindowStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/SidePanelTasksStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/ListWindowStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/TitleBarStyles.xaml"/>
                <ResourceDictionary Source="/Resource/Styles/SettingWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
